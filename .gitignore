```gitignore
# Dependencies
vendor/

# Environment
.env
.env.local
.env.*

# Logs
*.log

# Temporary files
*.tmp
*.swp
*~

# OS generated files
.DS_Store
Thumbs.db

# PHP specific
*.php~
*.php.bak
.php_cs.cache

# Database
*.sql
*.db
*.sqlite

# Cache
.cache/
*.cache

# Backup files
*.bak
*.backup
*~
```